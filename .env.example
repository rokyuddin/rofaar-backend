# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL via postgres.js)
DATABASE_URL=postgresql://user:password@localhost:5432/rofaar

# JWT
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# API Documentation
ENABLE_SWAGGER=true
API_HOST=localhost:3000

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rofaar
R2_PUBLIC_URL=
